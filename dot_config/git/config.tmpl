# ~/.config/git/config — managed by chezmoi (XDG location)
# Identity comes from per-machine ~/.config/chezmoi/chezmoi.toml

[user]
	name = {{ .name }}
	email = {{ .email }}

# Auto-switch identity based on directory. Paths come from chezmoi data
# (git_dir_personal / git_dir_work) so they can be overridden per machine.
# Blocks are harmless when their gitdir doesn't exist on this machine.
[includeIf "gitdir:{{ index . "git_dir_personal" | default "~/github/personal/" }}"]
	path = ~/.config/git/config-personal
[includeIf "gitdir:{{ index . "git_dir_work" | default "~/github/work/" }}"]
	path = ~/.config/git/config-work

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true

[commit]
	verbose = true

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = -version:refname

[rerere]
	enabled = true
	autoupdate = true

[core]
	editor = vim

[mergetool]
	keepBackup = false

[difftool]
	prompt = false

[help]
	autocorrect = 1

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
	count = !git shortlog -sn

[url "https://github.com/"]
	insteadOf = git@github.com:

[credential "https://github.com"]
	helper =
{{- if eq .chezmoi.os "darwin" }}
	helper = !/opt/homebrew/bin/gh auth git-credential
{{- else if eq .chezmoi.os "linux" }}
	helper = !/usr/bin/gh auth git-credential
{{- end }}

[credential "https://gist.github.com"]
	helper =
{{- if eq .chezmoi.os "darwin" }}
	helper = !/opt/homebrew/bin/gh auth git-credential
{{- else if eq .chezmoi.os "linux" }}
	helper = !/usr/bin/gh auth git-credential
{{- end }}

[credential]
{{- if eq .chezmoi.os "darwin" }}
	helper = !/opt/homebrew/bin/gh auth git-credential
{{- else if eq .chezmoi.os "linux" }}
	helper = !/usr/bin/gh auth git-credential
{{- end }}
