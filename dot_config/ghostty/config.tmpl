# ~/.config/ghostty/config — managed by chezmoi

# Theme
{{ if eq .chezmoi.os "darwin" -}}
theme = "{{ .theme_ghostty }}"
{{- else if eq .chezmoi.os "linux" -}}
# Dynamic theme via omarchy — switches automatically when you change
# theme on omarchy. The `?` prefix means "include if exists".
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"
{{- end }}

# Font (Ghostty bundles JetBrainsMono Nerd Font on macOS — works without install)
font-family = "JetBrainsMono Nerd Font"
font-style = Regular
{{ if eq .chezmoi.os "darwin" -}}
font-size = 14
{{- else if eq .chezmoi.os "linux" -}}
font-size = 9
{{- end }}

# Window
window-theme = ghostty
window-padding-x = 14
window-padding-y = 14
confirm-close-surface = false
resize-overlay = never
{{ if eq .chezmoi.os "linux" -}}
gtk-toolbar-style = flat
{{- end }}

# Auto-copy on selection. Use `clipboard` (not `true`) — on macOS, `true`
# means the X11 primary-selection clipboard which doesn't exist there.
# https://github.com/ghostty-org/ghostty/discussions/10346
copy-on-select = clipboard

# Cursor
cursor-style = "block"
cursor-style-blink = false

# Cursor styling override + SSH session terminfo
shell-integration-features = no-cursor,ssh-env

# Keyboard bindings (`super` = Cmd on Mac, Windows/Meta on Linux)
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100

# Slow down mouse scrolling
mouse-scroll-multiplier = 0.95

{{ if eq .chezmoi.os "linux" -}}
# Fix general slowness on Hyprland
# (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
{{- end }}
